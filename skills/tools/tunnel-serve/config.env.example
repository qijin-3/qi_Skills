# tunnel-serve 用户配置（复制为 config.env 后填写）
#
#   cp config.env.example config.env
#
# 或由 Agent / 交互脚本生成：
#   bash scripts/init-config.sh

# Cloudflare 根域名（Zone）。域名须已添加到 Cloudflare 账户。
# 获取：Cloudflare Dashboard → 添加站点 → 完成 DNS 托管
# 示例：example.com
TS_ZONE=

# 对外访问的子域名（公网 URL = https://<TS_SUBDOMAIN>.<TS_ZONE>/<slug>/）
# 建议：share、static、preview 等未被其他服务占用的名称
TS_SUBDOMAIN=share

# cloudflared 隧道名称（账户内唯一，仅字母数字连字符）
# bootstrap 会创建此隧道；与 TS_SUBDOMAIN 可相同也可不同
TS_TUNNEL_NAME=share

# 本地路由服务端口（须与 cloudflared ingress 一致，默认 8787）
TS_PORT=8787

# 首次 expose 后自动关闭的秒数（3600 = 1 小时；extend.sh 0 可改为永不）
TS_DEFAULT_TTL=3600

# --- 可选（一般无需修改）---

# cloudflared 配置目录（默认 ~/.cloudflared）
# TS_CF_HOME=

# cloudflared 配置文件路径（默认 $TS_CF_HOME/config.yml）
# TS_CF_CONFIG=
