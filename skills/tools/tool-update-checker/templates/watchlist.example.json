{
  "_comment": "tool-update-checker 关注列表模板。复制本文件到 ~/.claude/tool-watchlist.json 并按需增删。每条记录一个要跟踪的工具。带 _comment 的字段仅供说明，可删除。",
  "tools": [
    {
      "_comment": "[类型1] npm 全局 CLI（装在 /usr/local 需 sudo）",
      "name": "lark-cli",
      "type": "cli",
      "check_method": "npm",
      "package": "@larksuite/cli",
      "current_command": "lark-cli --version",
      "update_note": "需 sudo: sudo npm i -g @larksuite/cli@latest"
    },
    {
      "_comment": "[类型2] 原生安装器（~/.local/bin），自带更新检查",
      "name": "claude-code",
      "type": "cli",
      "check_method": "native",
      "current_command": "claude --version",
      "update_command": "claude update",
      "latest_source": "npm view @anthropic-ai/claude-code version"
    },
    {
      "_comment": "[类型3] brew 安装的 CLI",
      "name": "supabase",
      "type": "cli",
      "check_method": "brew",
      "package": "supabase",
      "current_command": "supabase --version"
    },
    {
      "_comment": "[类型4] GitHub releases 安装的 CLI（无包管理器）",
      "name": "opencode",
      "type": "cli",
      "check_method": "github",
      "repo": "sst/opencode",
      "current_command": "opencode --version"
    },
    {
      "_comment": "[类型5] Claude Code 插件（检查全部已装插件）",
      "name": "cc-plugins",
      "type": "plugins",
      "check_method": "cc-plugin"
    },
    {
      "_comment": "[类型6] marketplace 安装的 skills（有 ~/.agents/.skill-lock.json 记录）。skill_names 列出要跟踪的具体 skill",
      "name": "lark-skills",
      "type": "skills",
      "check_method": "marketplace",
      "source": "larksuite/cli",
      "skill_names": [
        "lark-base", "lark-calendar", "lark-contact", "lark-doc", "lark-drive",
        "lark-event", "lark-im", "lark-mail", "lark-minutes", "lark-openapi-explorer",
        "lark-shared", "lark-sheets", "lark-skill-maker", "lark-task", "lark-vc",
        "lark-whiteboard", "lark-wiki", "lark-workflow-meeting-summary", "lark-workflow-standup-report"
      ]
    },
    {
      "_comment": "[类型7-模板] 手动下载的游离 skill（不在 skills CLI 体系内）。复制本条并填入实际信息",
      "name": "some-manual-skill",
      "type": "skills",
      "check_method": "github",
      "repo": "owner/repo",
      "local_path": "~/.claude/skills/some-manual-skill"
    }
  ]
}
